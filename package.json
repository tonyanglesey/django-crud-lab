{
  "scripts": {
    "build:css": "tailwindcss -i ./static/src/input.css -o ./static/css/styles.css",
    "watch:css": "tailwindcss -i ./static/src/input.css -o ./static/css/styles.css --watch",
    "copy:htmx": "cp node_modules/htmx.org/dist/htmx.min.js static/vendor/htmx.min.js",
    "build": "npm run copy:htmx && npm run build:css"
  },
  "dependencies": {
    "htmx.org": "^2.0.10"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.3.1"
  }
}
